{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(shinkansen_http_server_duration_count{job=\"otel-collector\"}[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(shinkansen_http_server_duration_count{http.status_code=~\"5..\"}[5m])) by (service) / sum(rate(shinkansen_http_server_duration_count[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0 },
        "overrides": []
      }
    },
    {
      "title": "p99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(shinkansen_http_server_duration_bucket[5m])) by (le, service))",
          "legendFormat": "{{service}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      }
    },
    {
      "title": "gRPC Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(shinkansen_rpc_server_duration_count{rpc.system=\"grpc\"}[5m])) by (rpc.service)",
          "legendFormat": "{{rpc.service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "gRPC p99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(shinkansen_rpc_server_duration_bucket{rpc.system=\"grpc\"}[5m])) by (le, rpc.service))",
          "legendFormat": "{{rpc.service}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      }
    },
    {
      "title": "gRPC Error Rate by Method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(shinkansen_rpc_server_duration_count{rpc.system=\"grpc\",rpc.grpc.status_code!=\"0\"}[5m])) by (rpc.service)",
          "legendFormat": "{{rpc.service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    }
  ],
